<h1>マイページ</h1>

<% if flash[:notice] %>
  <div class="alert alert-success" role="alert">
    <%= flash[:notice] %>
  </div>
<% end %>

<div class="card mb-3">
  <div class="card-body">
    <p class="card-title">ユーザー名: <%= @user.name %></p>
    <p class="card-text">メールアドレス: <%= @user.email %></p>
  </div>
</div>

<div class="d-flex justify-content-start gap-3 mt-4">
  <%= link_to "ユーザー情報編集", edit_user_registration_path, class: "btn btn-outline-primary" %>
  <%= link_to "日別一覧", root_path, class: "btn btn-primary"%>
</div>
