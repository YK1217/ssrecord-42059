<% if resource.errors.any? %>
  <div id="error_explanation" data-turbo-temporary>
    <div class="alert alert-danger" role="alert">
      <h4 class="alert-heading h6">
        入力内容を確認してください
      </h4>

      <ul class="mb-0 ps-3">
        <% resource.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  </div>
<% end %>
