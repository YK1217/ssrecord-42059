<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
      <div class="card shadow">
        <div class="card-body p-4">
          <h1 class="h3 text-center mb-4"><%= form_title %></h1>

          <%= render "shared/error_messages", resource: record %>

          <%= form_with model: record, local: true do |f| %>
            <div class="mb-3">
              <%= f.label :start_time, start_time_label, class: "form-label" %>
              <%= f.datetime_field :start_time, class: "form-control" %>
            </div>

            <div class="mb-3">
              <%= f.label :end_clock, end_clock_label, class: "form-label" %>
              <%= f.time_field :end_clock, class: "form-control" %>

              <div class="form-text">
                未入力の場合は、終了時刻未登録の記録として保存されます。
              </div>
            </div>

            <% if defined?(extra_fields_partial) && extra_fields_partial.present? %>
              <%= render extra_fields_partial, f: f %>
            <% end %>

            <div class="d-grid">
              <%= f.submit record.new_record? ? "登録する" : "更新する" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
