<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
      <div class="card shadow">
        <div class="card-body p-4">
          <h1 class="h3 text-center mb-4">睡眠時間登録</h1>

          <%= render "shared/error_messages", resource: @sleep_record %>

          <%= form_with model: @sleep_record, local: true do |f| %>
            <div class="mb-3">
              <%= f.label :start_time, "就寝日時", class: "form-label" %>
              <%= f.datetime_field :start_time, class: "form-control" %>
            </div>

            <div class="mb-3">
              <%= f.label :end_clock, "起床時刻", class: "form-label" %>
              <%= f.time_field :end_clock, class: "form-control" %>
              <div class="form-text">
                未入力の場合は、終了時刻未登録の記録として保存されます。
              </div>
            </div>

            <div class="d-grid">
              <%= f.submit "登録する", class: "btn btn-primary" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
